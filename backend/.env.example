# BridgeWatch AI Backend Configuration

# Application
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bridgewatch

# JWT
SECRET_KEY=bridgewatch-dev-secret-key-change-in-production

# File storage
FILE_STORAGE_PATH=./data/files

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
